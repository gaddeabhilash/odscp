PORT=5000
NODE_ENV=development

# Option 1: Full MongoDB connection URI
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.fxxjgvq.mongodb.net/odscp?retryWrites=true&w=majority

# Option 2: Non-SRV direct connection string builder
# MONGO_HOSTS=ac-njxkaks-shard-00-00.fxxjgvq.mongodb.net:27017,ac-njxkaks-shard-00-01.fxxjgvq.mongodb.net:27017,ac-njxkaks-shard-00-02.fxxjgvq.mongodb.net:27017
# MONGO_USER=<user>
# MONGO_PASS=<password>
# MONGO_DB=odscp
# MONGO_OPTIONS=retryWrites=true&w=majority

MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1
JWT_SECRET=your_jwt_secret_key
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
